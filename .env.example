HOST=127.0.0.1
PORT=3101
VITE_API_BASE_URL=http://127.0.0.1:3101

# Production mounts may separate curated source data from generated run output.
# Both default to server/data when left blank for local compatibility.
EVIDENCE_DATA_DIR=
EVIDENCE_RUNTIME_DIR=
# Optional public origin used only when Evidence assets are intentionally exposed.
# Canvas production normally imports assets into its own user library instead.
EVIDENCE_PUBLIC_BASE_URL=

# Server-only token used by MYML Canvas server when calling /v1/* Evidence Agent APIs.
# Do not expose this value to the browser.
MYML_EVIDENCE_AGENT_TOKEN=

# Default and only runtime lookup path for this slim build.
COMPANY_LOOKUP_SOURCE=db_minimal

# Read-only company DB lookup. Do not put real secrets in this file.
COMPANY_DB_HOST=
COMPANY_DB_PORT=3306
COMPANY_DB_NAME=
COMPANY_DB_USER=
COMPANY_DB_PASSWORD=
COMPANY_DB_VIEW=
COMPANY_DB_PROJECT_CODE_COLUMN=project_code
COMPANY_DB_TIMEOUT_MS=10000

# Optional base URL for resolving company reference image paths if the DB view stores relative temp/... values.
COMPANY_REFERENCE_IMAGE_BASE_URL=

# AI element mapping. The API key belongs only in local .env and must not be committed.
AI_ELEMENT_MAPPER_ENABLED=true
AI_ELEMENT_MAPPER_BASE_URL=
AI_ELEMENT_MAPPER_ENDPOINT_PATH=/chat/completions
AI_ELEMENT_MAPPER_API_KEY=
AI_ELEMENT_MAPPER_MODEL=gpt-5.5
AI_ELEMENT_MAPPER_TIMEOUT_MS=90000
AI_ELEMENT_MAPPER_MAX_TOKENS=1200
AI_ELEMENT_MAPPER_TOP_N=40
AI_ELEMENT_MAPPER_RESPONSE_FORMAT=json_object

# Optional AI category classifier. Leave blank to reuse AI_ELEMENT_MAPPER_*.
AI_CATEGORY_CLASSIFIER_ENABLED=
AI_CATEGORY_CLASSIFIER_BASE_URL=
AI_CATEGORY_CLASSIFIER_ENDPOINT_PATH=
AI_CATEGORY_CLASSIFIER_API_KEY=
AI_CATEGORY_CLASSIFIER_MODEL=
AI_CATEGORY_CLASSIFIER_TIMEOUT_MS=
AI_CATEGORY_CLASSIFIER_MAX_TOKENS=
AI_CATEGORY_CLASSIFIER_RESPONSE_FORMAT=

# Optional AI gallery image filter. Leave blank to reuse AI_ELEMENT_MAPPER_*.
AI_GALLERY_IMAGE_FILTER_ENABLED=
AI_GALLERY_IMAGE_FILTER_BASE_URL=
AI_GALLERY_IMAGE_FILTER_ENDPOINT_PATH=
AI_GALLERY_IMAGE_FILTER_API_KEY=
AI_GALLERY_IMAGE_FILTER_MODEL=
AI_GALLERY_IMAGE_FILTER_TIMEOUT_MS=
AI_GALLERY_IMAGE_FILTER_MAX_TOKENS=
AI_GALLERY_IMAGE_FILTER_RESPONSE_FORMAT=
AI_GALLERY_IMAGE_FILTER_MAX_IMAGES=12
AI_GALLERY_IMAGE_FILTER_MIN_SCORE=0.62

# Optional AI image generation. Put the real key only in local .env.
AI_IMAGE_GENERATOR_ENABLED=true
AI_IMAGE_GENERATOR_BASE_URL=
AI_IMAGE_GENERATOR_ENDPOINT_PATH=/images/edits
AI_IMAGE_GENERATOR_API_KEY=
AI_IMAGE_GENERATOR_MODEL=gpt-image-2
AI_IMAGE_GENERATOR_REQUEST_MODE=edits
AI_IMAGE_GENERATOR_TIMEOUT_MS=600000
# Use 2048x2048 for 2K generation when the upstream image model supports it.
AI_IMAGE_GENERATOR_SIZE=2048x2048
AI_IMAGE_GENERATOR_QUALITY=standard
AI_IMAGE_GENERATOR_STYLE=vivid
AI_IMAGE_GENERATOR_N=1
AI_IMAGE_GENERATOR_RESPONSE_FORMAT=url
AI_IMAGE_GENERATOR_EMBED_INPUT_IMAGES=true
AI_IMAGE_GENERATOR_MAX_INPUT_IMAGE_BYTES=8388608
AI_IMAGE_GENERATOR_IMAGE_FIELD_NAME=image

# Optional read-only element gallery relationship view. The app only reads the prebuilt index.
MYML_DESIGN_KNOWLEDGE_BASE_PATH=
ELEMENT_SOURCE_GALLERY_INDEX_PATH=
ELEMENT_GALLERY_MAX_IMAGES_PER_TERM=8
ELEMENT_GALLERY_MAX_GRAPH_IMAGES=40
